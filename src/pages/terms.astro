---
import Layout from '@/components/Layout.astro';
---

<Layout fullTitle="Terms — UK Exit Advisors" description="Terms of use for UK Exit Advisors." canonical={new URL('/terms/', Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Terms</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Terms of use</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">These starter terms cover basic site use, directory information and liability. Replace the placeholder sections below with your final business terms before publishing.</p>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="max-w-4xl space-y-6 text-sm leading-7 text-slate-600">
      <p><span class="font-medium text-slate-900">Use of the site.</span> The directory is provided for general information and comparison purposes only.</p>
      <p><span class="font-medium text-slate-900">Accuracy.</span> We aim to keep listings current, but firms should verify details before relying on them.</p>
      <p><span class="font-medium text-slate-900">Placeholder note.</span> Add your company identity, governing law, disclaimers and liability limits here.</p>
    </div>
  </section>
</Layout>
