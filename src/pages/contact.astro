---
import Layout from '@/components/Layout.astro';
---

<Layout title="Contact — UK Exit Advisors" description="Contact UK Exit Advisors about claims, corrections, press and editorial queries.">
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-5xl">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Contact and editorial enquiries</h1>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">For business owners</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">UK Exit Advisors does not pass your details to listed firms. To contact an advisor, visit their profile and use the contact details they've published. For feedback on the directory or a specific listing, email <a href="mailto:info@ukexitadvisors.co.uk" class="underline decoration-stone-300 underline-offset-4">info@ukexitadvisors.co.uk</a> and we'll respond within 2 working days.</p>
        </div>

        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">For firms</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">To claim, correct, upgrade or remove your listing, email <a href="mailto:info@ukexitadvisors.co.uk" class="underline decoration-stone-300 underline-offset-4">info@ukexitadvisors.co.uk</a> with your firm name in the subject line. We'll verify the request and respond within 2 working days. For pricing and listing options, see <a href="/for-advisors/" class="underline decoration-stone-300 underline-offset-4">/for-advisors/</a>.</p>
        </div>

        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">For press and editorial</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">Media enquiries: <a href="mailto:info@ukexitadvisors.co.uk?subject=Press%20enquiry" class="underline decoration-stone-300 underline-offset-4">info@ukexitadvisors.co.uk</a> (subject: 'Press enquiry').</p>
        </div>

        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">Operator details</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">UK Exit Advisors is operated by Rehan Baig, London, United Kingdom.<br />
          <a href="mailto:info@ukexitadvisors.co.uk" class="underline decoration-stone-300 underline-offset-4">info@ukexitadvisors.co.uk</a></p>
        </div>
      </div>
    </div>
  </section>
</Layout>
