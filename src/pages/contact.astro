---
import Layout from '@/components/Layout.astro';
---

<Layout title="Contact" description="Contact UK Exit Advisors to claim or correct a profile.">
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Claim or correct a profile</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">Email us for claims, corrections or updates.</p>
      <div class="mt-8 card p-6">
        <p class="text-sm font-medium text-slate-900">Email</p>
        <a href="mailto:hello@ukexitadvisors.co.uk" class="mt-2 inline-block text-sm text-slate-700 underline decoration-stone-300 underline-offset-4">hello@ukexitadvisors.co.uk</a>
      </div>
    </div>
  </section>
</Layout>
