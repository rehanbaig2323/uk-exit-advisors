---
import Layout from '@/components/Layout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { getSupportedSectorPages, getMatchingSectorAdvisors } from '@/data/seo';
import ItemListSchema from '@/components/ItemListSchema.astro';

const pages = getSupportedSectorPages();
const itemList = pages.map((page) => ({ name: page.h1, href: `/sectors/${page.slug}/` }));
---

<Layout fullTitle="Sectors — UK Exit Advisors" description="Sector landing pages for the UK exit-advisor directory.">
  <ItemListSchema items={itemList} />
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Sectors</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Compare exit advisors by sector.</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">These are the sector hubs with enough public evidence to be genuinely useful. Each page shows relevant firms, sector-specific context and links into the matching route guides.</p>
    </div>
  </section>

  <section class="container-page py-8">
    <SectionHeading eyebrow="Available hubs" title="Indexable sector pages" copy="Only sectors with a useful number of matching firms are published." />
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {pages.map((page) => {
        const count = getMatchingSectorAdvisors(page.slug).length;
        return (
          <a href={`/sectors/${page.slug}/`} class="card block p-6 hover:-translate-y-0.5 hover:shadow-soft">
            <h2 class="text-lg font-semibold text-slate-900">{page.h1}</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">{page.description}</p>
            <p class="mt-4 text-sm font-medium text-ink">{count} matching firms →</p>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
