---
import Layout from '@/components/Layout.astro';

const lastUpdated = 'April 2026';
---

<Layout fullTitle="Privacy policy — UK Exit Advisors" description="Privacy policy for UK Exit Advisors." canonical={new URL('/privacy/', Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Privacy</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Privacy policy</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">Last updated {lastUpdated}. This starter policy explains how the site handles newsletter signups, contact requests and general browsing data. Replace the placeholder sections below with your final legal wording before publishing commercially.</p>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="max-w-4xl space-y-6 text-sm leading-7 text-slate-600">
      <p><span class="font-medium text-slate-900">What we collect.</span> We may collect email addresses, contact details you submit, and basic analytics about site usage.</p>
      <p><span class="font-medium text-slate-900">How we use it.</span> We use information to reply to enquiries, send updates if you subscribe, and improve the site.</p>
      <p><span class="font-medium text-slate-900">What still needs final legal review.</span> Insert your company details, data controller identity, lawful bases, retention periods, and processor list here.</p>
    </div>
  </section>
</Layout>
