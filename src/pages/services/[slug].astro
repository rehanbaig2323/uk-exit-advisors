---
import Layout from '@/components/Layout.astro';
import { services } from '@/data/services';

export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service } = Astro.props;
---

<Layout title={service.name} description={service.summary} canonical={new URL(`/services/${service.slug}/`, Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Adviser type</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{service.name}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{service.summary}</p>
      <a href="/advisors/" class="mt-8 inline-flex rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white hover:bg-slate-800">Browse advisors</a>
    </div>
  </section>
</Layout>
