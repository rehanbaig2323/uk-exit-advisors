---
import Layout from '@/components/Layout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import AdvisorCard from '@/components/AdvisorCard.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ItemListSchema from '@/components/ItemListSchema.astro';
import { advisorsData } from '@/data/advisors';
import { services } from '@/data/services';
import { routes } from '@/data/routes';
import { getServicePageContent, matchesService } from '@/data/service-page-content';
import { getBreadcrumbItems, getPageCanonical } from '@/data/seo';

export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service } = Astro.props;
const content = getServicePageContent(service.slug);
const matchingAdvisors = advisorsData
  .filter((advisor) => matchesService(advisor, service.slug))
  .sort((a, b) => Number(b.featured) - Number(a.featured) || a.name.localeCompare(b.name));

const routeCards = (content?.relatedRoutes || [])
  .map((slug) => routes.find((route) => route.slug === slug))
  .filter((route): route is (typeof routes)[number] => Boolean(route));

const pageDescription = content
  ? `${service.summary} ${content.intro[0]}`
  : service.summary;

const breadcrumbItems = getBreadcrumbItems([
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: service.name, href: `/services/${service.slug}/` },
]);

const itemList = matchingAdvisors.map((advisor) => ({ name: advisor.name, href: `/advisors/${advisor.slug}/` }));
---

<Layout title={service.name} description={pageDescription} canonical={getPageCanonical(`/services/${service.slug}/`)}>
  <ItemListSchema items={itemList} itemType="https://schema.org/ProfessionalService" />
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <Breadcrumbs items={breadcrumbItems} />
      <p class="eyebrow mt-6">Adviser type</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{service.name}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{service.summary}</p>
      <a href="/advisors/" class="mt-8 inline-flex rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white hover:bg-slate-800">Browse advisors</a>
    </div>
  </section>

  {content ? (
    <section class="container-page pb-8">
      <div class="max-w-4xl space-y-6 text-base leading-8 text-slate-600">
        {content.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  ) : null}

  {content ? (
    <section class="container-page py-8">
      <SectionHeading eyebrow="Guide" title={`${service.name} in an exit process`} copy="Use this page to compare firms, understand when the adviser matters and link into the relevant route pages." />
      <div class="mt-8 grid gap-4 lg:grid-cols-2">
        {content.sections.map((section) => (
          <article class="card p-6">
            <h2 class="text-lg font-semibold text-slate-900">{section.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{section.body}</p>
          </article>
        ))}
      </div>
      <div class="mt-8 grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">What to compare between firms</h2>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
            {content.comparePoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>
        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">Related exit routes</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {routeCards.map((route) => <a href={`/routes/${route.slug}/`} class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-calm hover:border-stone-300 hover:text-ink">{route.name}</a>)}
          </div>
          <p class="mt-4 text-sm leading-7 text-slate-600">These routes are where owners most often need this adviser type. Start with the route page, then compare firms that have recent, relevant work in the same area.</p>
        </div>
      </div>
    </section>
  ) : null}

  <section class="container-page py-8">
    <SectionHeading eyebrow="Advisors" title={`Matching ${service.name} specialists`} copy={`${matchingAdvisors.length} firms currently match this adviser type.`} />
    <div class="mt-8 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
      {matchingAdvisors.map((advisor) => <AdvisorCard advisor={advisor} />)}
    </div>
    {matchingAdvisors.length === 0 ? <p class="mt-6 text-sm text-slate-600">No exact matches yet. Browse the full <a href="/advisors/" class="underline decoration-stone-300 underline-offset-4">advisor directory</a>.</p> : null}
  </section>

  {content ? (
    <section class="container-page py-8">
      <SectionHeading eyebrow="Next steps" title="Compare across routes" copy="If you are still deciding how to exit, these route pages help you compare the most common outcomes." />
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {routeCards.map((route) => (
          <a href={`/routes/${route.slug}/`} class="card p-6 hover:-translate-y-0.5 hover:shadow-soft">
            <h3 class="text-lg font-semibold text-slate-900">{route.name}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{route.summary}</p>
          </a>
        ))}
      </div>
    </section>
  ) : null}
</Layout>
