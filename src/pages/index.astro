---
import Layout from '@/components/Layout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import RouteCard from '@/components/RouteCard.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import FeaturedAdvisorCard from '@/components/FeaturedAdvisorCard.astro';
import { site } from '@/lib/site';
import { advisorsData } from '@/data/advisors';
import { routes } from '@/data/routes';
import { services } from '@/data/services';

const firmCount = advisorsData.length;
const currentMonth = new Date();
currentMonth.setDate(1);
const lastReviewed = currentMonth.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const featuredAdvisorSlugs = [
  'gp-bullhound',
  'postlethwaite-solicitors',
  'burges-salmon',
  'cazenove-capital',
  'hawsons-corporate-finance',
  'moore-kingston-smith',
];

const featuredAdvisors = featuredAdvisorSlugs
  .map((slug) => advisorsData.find((advisor) => advisor.slug === slug))
  .filter((advisor): advisor is (typeof advisorsData)[number] => Boolean(advisor));
---

<Layout title={site.headline} description={site.subheadline}>
  <section class="border-b border-line bg-white/75">
    <div class="container-page py-20 sm:py-24">
      <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div class="max-w-3xl">
          <span class="hero-kicker">{site.domain}</span>
          <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-6xl">The independent directory of UK business-exit advisors.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">For owners planning a trade sale, EOT, MBO, succession or partial exit - compare specialist UK firms by sector, deal size and location. No lead forms. No commission. No paywall for owners.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/advisors/" class="button-primary">Browse advisors</a>
            <a href="/route-finder/" class="button-secondary">Which exit route fits me?</a>
          </div>
        </div>

        <div class="card-subtle p-6 sm:p-8">
          <div class="rounded-3xl border border-line bg-white p-6 shadow-sm">
            <div class="space-y-4 text-sm leading-6 text-calm">
              <p><span class="font-semibold text-ink">{firmCount} specialist firms</span></p>
              <p>Covering deals £1m-£300m</p>
              <p>Trade sale · EOT · MBO · Succession · Partial exit</p>
              <p>Last reviewed: {lastReviewed}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-line bg-white/90">
    <div class="container-page py-4 sm:py-5">
      <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.16em] text-brass">
        <span class="font-semibold text-ink">Advisors featured include</span>
        <div class="flex flex-wrap gap-x-2 gap-y-1 text-calm normal-case tracking-normal">
          {['Cavendish Corporate Finance', 'Arrowpoint Advisory', 'GP Bullhound', 'Burges Salmon', 'Moore Kingston Smith', 'Brabners', 'Saffery', 'Cazenove Capital'].map((name) => <span>{name}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-16">
    <SectionHeading eyebrow="Featured advisors" title="Firms owners compare first" copy="A tighter selection of firms spanning different routes, sectors and locations." />
    <div class="mt-8 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
      {featuredAdvisors.map((advisor) => advisor ? <FeaturedAdvisorCard advisor={advisor} /> : null)}
    </div>
  </section>

  <section class="container-page py-16 sm:py-20">
    <SectionHeading eyebrow="Trust" title="Built for owner decisions" copy="Clear adviser data, simple comparison, no clutter." />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <div class="card p-6"><p class="font-medium text-slate-900">Clear metadata</p><p class="mt-2 text-sm text-slate-600">City, services, routes and verification.</p></div>
      <div class="card p-6"><p class="font-medium text-slate-900">Simple comparison</p><p class="mt-2 text-sm text-slate-600">Search and filter fast.</p></div>
    </div>
  </section>

  <section class="container-page py-8">
    <SectionHeading eyebrow="Exit routes" title="Compare by route" />
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {routes.map((route) => <RouteCard route={route} />)}
    </div>
  </section>

  <section class="container-page py-16">
    <SectionHeading eyebrow="Adviser types" title="Specialists by need" />
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {services.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section class="container-page py-16">
    <SectionHeading eyebrow="How it works" title="Search. Compare. Contact." />
    <div class="mt-8 card p-6">
      <div class="grid gap-4 md:grid-cols-3">
        <div><p class="font-medium text-slate-900">1. Search</p><p class="mt-2 text-sm text-slate-600">By route or location.</p></div>
        <div><p class="font-medium text-slate-900">2. Compare</p><p class="mt-2 text-sm text-slate-600">See the essentials.</p></div>
        <div><p class="font-medium text-slate-900">3. Contact</p><p class="mt-2 text-sm text-slate-600">Go direct or claim.</p></div>
      </div>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="card grid gap-6 p-8 lg:grid-cols-[1.3fr_0.7fr] lg:items-center">
      <div>
        <p class="eyebrow">For advisors</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">Get in front of owners actively planning an exit.</h2>
        <p class="mt-3 text-base leading-7 text-slate-600">Free listing by default.</p>
        <p class="text-base leading-7 text-slate-600">Paid upgrades are clearly labelled.</p>
        <p class="text-base leading-7 text-slate-600">Main search results stay neutral.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/for-advisors/" class="button-primary">View advisor options</a>
          <a href="/contact/" class="button-secondary">Claim or correct a profile</a>
        </div>
      </div>
      <div class="rounded-3xl border border-line bg-mist/70 p-6 text-sm text-calm">
        <p class="font-medium text-ink">What firms get</p>
        <p class="mt-3">Basic listing, optional upgrade and a claim/correct path.</p>
      </div>
    </div>
  </section>
</Layout>
