---
import Layout from '@/components/Layout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import RouteCard from '@/components/RouteCard.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import { site } from '@/lib/site';
import { routes } from '@/data/routes';
import { services } from '@/data/services';
---

<Layout title={site.headline} description={site.subheadline}>
  <section class="border-b border-line bg-white/75">
    <div class="container-page py-20 sm:py-24">
      <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div class="max-w-3xl">
          <span class="hero-kicker">{site.domain}</span>
          <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-6xl">{site.headline}</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{site.subheadline}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/advisors/" class="button-primary">Browse advisors</a>
            <a href="/contact/" class="button-secondary">Claim a profile</a>
          </div>
        </div>

        <div class="card-subtle p-6 sm:p-8">
          <div class="rounded-3xl border border-line bg-white p-6">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <p class="text-xs uppercase tracking-[0.16em] text-brass">Directory</p>
                <p class="mt-2 text-sm leading-6 text-calm">15 verified firms currently listed.</p>
              </div>
            <div>
              <p class="text-xs uppercase tracking-[0.16em] text-brass">Coverage</p>
              <p class="mt-2 text-sm leading-6 text-calm">Trade sale, EOT, MBO, succession and partial exit.</p>
            </div>
            <div>
                <p class="text-xs uppercase tracking-[0.16em] text-brass">Profiles</p>
                <p class="mt-2 text-sm leading-6 text-calm">Free and enhanced options.</p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-[0.16em] text-brass">Updates</p>
                <p class="mt-2 text-sm leading-6 text-calm">Simple claim and correction path.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-16 sm:py-20">
    <SectionHeading eyebrow="Trust" title="Built for owner decisions" copy="Clear adviser data, simple comparison, no clutter." />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <div class="card p-6"><p class="font-medium text-slate-900">Clear metadata</p><p class="mt-2 text-sm text-slate-600">City, services, routes and verification.</p></div>
      <div class="card p-6"><p class="font-medium text-slate-900">Simple comparison</p><p class="mt-2 text-sm text-slate-600">Search and filter fast.</p></div>
    </div>
  </section>

  <section class="container-page py-8">
    <SectionHeading eyebrow="Exit routes" title="Compare by route" />
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {routes.map((route) => <RouteCard route={route} />)}
    </div>
  </section>

  <section class="container-page py-16">
    <SectionHeading eyebrow="Adviser types" title="Specialists by need" />
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {services.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section class="container-page py-16">
    <SectionHeading eyebrow="How it works" title="Search. Compare. Contact." />
    <div class="mt-8 card p-6">
      <div class="grid gap-4 md:grid-cols-3">
        <div><p class="font-medium text-slate-900">1. Search</p><p class="mt-2 text-sm text-slate-600">By route or location.</p></div>
        <div><p class="font-medium text-slate-900">2. Compare</p><p class="mt-2 text-sm text-slate-600">See the essentials.</p></div>
        <div><p class="font-medium text-slate-900">3. Contact</p><p class="mt-2 text-sm text-slate-600">Go direct or claim.</p></div>
      </div>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="card grid gap-6 p-8 lg:grid-cols-[1.3fr_0.7fr] lg:items-center">
      <div>
        <p class="eyebrow">For advisors</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">For advisors</h2>
        <p class="mt-3 text-base leading-7 text-slate-600">Free profile now. Enhanced profile if you want more visibility.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/for-advisors/" class="button-primary">View advisor options</a>
          <a href="/contact/" class="button-secondary">Claim or correct a profile</a>
        </div>
      </div>
      <div class="rounded-3xl border border-line bg-mist/70 p-6 text-sm text-calm">
        <p class="font-medium text-ink">What firms get</p>
        <p class="mt-3">Basic listing, optional upgrade and a claim/correct path.</p>
      </div>
    </div>
  </section>
</Layout>
