---
import Layout from '@/components/Layout.astro';
import { advisorsData } from '@/data/advisors';

export function getStaticPaths() {
  return advisorsData.map((advisor) => ({ params: { slug: advisor.slug }, props: { advisor } }));
}

const { advisor } = Astro.props;
---

<Layout title={advisor.name} description={advisor.shortDescription} canonical={new URL(`/advisors/${advisor.slug}/`, Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-4xl">
      <p class="eyebrow">Advisor profile</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{advisor.name}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{advisor.shortDescription}</p>

      <div class="mt-8 grid gap-4 lg:grid-cols-2">
        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">Overview</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">{advisor.longDescription}</p>
        </div>
        <div class="card p-6">
          <h2 class="text-lg font-semibold text-slate-900">Contact</h2>
          <dl class="mt-4 grid gap-3 text-sm text-slate-600">
            <div><dt class="font-medium text-slate-900">Website</dt><dd><a href={advisor.website} class="break-all underline decoration-stone-300 underline-offset-4">{advisor.website}</a></dd></div>
            <div><dt class="font-medium text-slate-900">Email</dt><dd><a href={`mailto:${advisor.email}`} class="underline decoration-stone-300 underline-offset-4">{advisor.email}</a></dd></div>
            <div><dt class="font-medium text-slate-900">Phone</dt><dd>{advisor.phone}</dd></div>
            <div><dt class="font-medium text-slate-900">Last verified</dt><dd>{advisor.lastVerified}</dd></div>
          </dl>
          <a href={`mailto:${advisor.email}?subject=Claim%20or%20correct%20profile%20for%20${encodeURIComponent(advisor.name)}`} class="mt-6 inline-flex rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:border-slate-400">Claim / correct profile</a>
        </div>
      </div>

      <div class="mt-6 card p-6">
        <h2 class="text-lg font-semibold text-slate-900">Key people, coverage and work</h2>
        <div class="mt-4 grid gap-6 md:grid-cols-3">
          <div>
            <p class="text-sm font-medium text-slate-900">Key people</p>
            <ul class="mt-3 space-y-2 text-sm text-slate-600">
              {advisor.keyPeople.map((person) => <li><span class="font-medium text-slate-900">{person.name}</span> · {person.title}</li>)}
            </ul>
          </div>
          <div>
            <p class="text-sm font-medium text-slate-900">Coverage</p>
            <p class="mt-3 text-sm text-slate-600">{advisor.exitRoutes.join(', ')}</p>
            <p class="mt-4 text-sm text-slate-600">{advisor.services.join(', ')}</p>
          </div>
          <div>
            <p class="text-sm font-medium text-slate-900">Notable work</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-600">
              {advisor.notableWork.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
