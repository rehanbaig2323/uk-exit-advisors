---
import Layout from '@/components/Layout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import AdvisorCard from '@/components/AdvisorCard.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ItemListSchema from '@/components/ItemListSchema.astro';
import { routes } from '@/data/routes';
import { services } from '@/data/services';
import { getBreadcrumbItems, getPageCanonical, getRouteLocationPages, getServiceLocationPages, getMatchingRouteLocationAdvisors, getMatchingServiceLocationAdvisors } from '@/data/seo';

export function getStaticPaths() {
  return [...getRouteLocationPages(), ...getServiceLocationPages()].map((page) => ({
    params: { category: page.slug.split('/')[0], location: page.slug.split('/')[1] },
    props: { page },
  }));
}

const { page } = Astro.props;
const [categorySlug, locationSlug] = page.slug.split('/');
const advisors = page.routeSlug
  ? getMatchingRouteLocationAdvisors(page.routeSlug, page.locationSlug)
  : getMatchingServiceLocationAdvisors(page.serviceSlug, page.locationSlug);
const itemList = advisors.map((advisor) => ({ name: advisor.name, href: `/advisors/${advisor.slug}/` }));
const breadcrumbItems = getBreadcrumbItems([
  { label: 'Home', href: '/' },
  { label: 'Advisors', href: '/advisors/' },
  { label: page.h1, href: `/advisors/${categorySlug}/${locationSlug}/` },
]);
---

<Layout fullTitle={page.title} description={page.description} canonical={getPageCanonical(`/advisors/${categorySlug}/${locationSlug}/`)}>
  <ItemListSchema items={itemList} itemType="https://schema.org/ProfessionalService" />
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-4xl">
      <Breadcrumbs items={breadcrumbItems} />
      <p class="eyebrow mt-6">Advisor hub</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{page.h1}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{page.description}</p>
      <p class="mt-3 text-xs uppercase tracking-[0.18em] text-slate-500">Last updated {page.lastUpdated}</p>
      <div class="mt-8 space-y-6 text-base leading-8 text-slate-600">
        {page.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="mt-8 flex flex-wrap gap-2">
        {page.relatedRoutes.map((slug) => {
          const route = routes.find((item) => item.slug === slug);
          return route ? <a href={`/routes/${route.slug}/`} class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-calm hover:border-stone-300 hover:text-ink">{route.name}</a> : null;
        })}
        {page.relatedServices.map((slug) => {
          const service = services.find((item) => item.slug === slug);
          return service ? <a href={`/services/${service.slug}/`} class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-calm hover:border-stone-300 hover:text-ink">{service.name}</a> : null;
        })}
      </div>
    </div>
  </section>

  <section class="container-page py-8">
    <SectionHeading eyebrow="Advisors" title={`Matching firms for ${page.h1}`} copy={`${advisors.length} firms currently match this page.`} />
    <div class="mt-8 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
      {advisors.map((advisor) => <AdvisorCard advisor={advisor} />)}
    </div>
  </section>
</Layout>
