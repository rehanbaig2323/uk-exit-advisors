---
import Layout from '@/components/Layout.astro';
import { routes } from '@/data/routes';

export function getStaticPaths() {
  return routes.map((route) => ({ params: { slug: route.slug }, props: { route } }));
}

const { route } = Astro.props;
---

<Layout title={route.name} description={route.summary} canonical={new URL(`/routes/${route.slug}/`, Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Exit route</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{route.name}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{route.description}</p>
      <a href="/advisors/" class="mt-8 inline-flex rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white hover:bg-slate-800">Compare advisors</a>
    </div>
  </section>
</Layout>
