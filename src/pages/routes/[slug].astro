---
import Layout from '@/components/Layout.astro';
import AdvisorCard from '@/components/AdvisorCard.astro';
import { advisorsData } from '@/data/advisors';
import { routes } from '@/data/routes';

export function getStaticPaths() {
  return routes.map((route) => ({ params: { slug: route.slug }, props: { route } }));
}

const { route } = Astro.props;

const routeKeywords: Record<string, string[]> = {
  'trade-sale': ['trade sale'],
  eot: ['eot', 'employee ownership'],
  mbo: ['mbo'],
  succession: ['succession'],
  'partial-exit': ['partial exit', 'investment'],
};

const compareRoutes = route.compareWith
  .map((name: string) => routes.find((item) => item.name === name))
  .filter((item): item is (typeof routes)[number] => Boolean(item));

const advisors = advisorsData.filter((advisor) => {
  const keywords = routeKeywords[route.slug] || [route.name.toLowerCase()];
  return advisor.exitRoutes.some((exitRoute) =>
    keywords.some((keyword) => exitRoute.toLowerCase().includes(keyword)),
  );
});
---

<Layout title={`${route.name} advisors — UK Exit Advisors`} description={route.summary} canonical={new URL(`/routes/${route.slug}/`, Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-4xl">
      <p class="eyebrow">Exit route</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{route.name}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{route.description}</p>
      <a href="/advisors/" class="mt-8 inline-flex rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white hover:bg-slate-800">See all advisors →</a>

      <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
        {advisors.map((advisor) => <AdvisorCard advisor={advisor} />)}
      </div>

      <div class="mt-10 border-t border-line pt-6 text-sm text-calm">
        <p class="font-medium text-ink">Often compared with:</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {compareRoutes.map((item) => <a href={`/routes/${item.slug}/`} class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-calm hover:border-stone-300 hover:text-ink">{item.name}</a>)}
        </div>
      </div>
    </div>
  </section>
</Layout>
