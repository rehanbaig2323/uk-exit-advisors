---
import Layout from '@/components/Layout.astro';
import AdvisorCard from '@/components/AdvisorCard.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ItemListSchema from '@/components/ItemListSchema.astro';
import { advisorsData } from '@/data/advisors';
import { routes } from '@/data/routes';
import { getRouteGuide, getBreadcrumbItems, getPageCanonical } from '@/data/seo';

export function getStaticPaths() {
  return routes.map((route) => ({ params: { slug: route.slug }, props: { route } }));
}

const { route } = Astro.props;
const guide = getRouteGuide(route.slug);

const compareRoutes = guide.compareWith
  .map((name: string) => routes.find((item) => item.name.toLowerCase() === name.toLowerCase() || item.slug === name))
  .filter((item): item is (typeof routes)[number] => Boolean(item));

const advisors = guide.relatedAdvisors
  .map((slug) => advisorsData.find((advisor) => advisor.slug === slug))
  .filter((advisor): advisor is (typeof advisorsData)[number] => Boolean(advisor))
  .sort((a, b) => Number(b.featured) - Number(a.featured) || a.name.localeCompare(b.name));

const breadcrumbItems = getBreadcrumbItems([
  { label: 'Home', href: '/' },
  { label: 'Exit routes', href: '/routes/' },
  { label: guide.h1, href: `/routes/${route.slug}/` },
]);

const itemList = advisors.map((advisor) => ({ name: advisor.name, href: `/advisors/${advisor.slug}/` }));

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: guide.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<Layout fullTitle={`${guide.title} | UK Exit Advisors`} description={guide.description} canonical={getPageCanonical(`/routes/${route.slug}/`)}>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <ItemListSchema items={itemList} itemType="https://schema.org/ProfessionalService" />
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-4xl">
      <Breadcrumbs items={breadcrumbItems} />
      <p class="eyebrow mt-6">Exit route</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{guide.h1}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{guide.description}</p>
      <p class="mt-3 text-xs uppercase tracking-[0.18em] text-slate-500">Last updated {guide.lastUpdated}</p>
      <div class="mt-8 space-y-6 text-base leading-8 text-slate-600">
        {guide.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="mt-8 flex flex-wrap gap-2">
        {compareRoutes.map((item) => <a href={`/routes/${item.slug}/`} class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-calm hover:border-stone-300 hover:text-ink">{item.name}</a>)}
      </div>

      <h2 class="mt-12 text-xl font-semibold tracking-tight text-slate-900">How the route works</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {guide.sections.map((section) => (
          <article class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">{section.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{section.body}</p>
          </article>
        ))}
      </div>

      <h2 class="mt-12 text-xl font-semibold tracking-tight text-slate-900">Frequently asked questions</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {guide.faqs.map((faq) => (
          <article class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">{faq.question}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{faq.answer}</p>
          </article>
        ))}
      </div>

      <h2 class="mt-12 text-xl font-semibold tracking-tight text-slate-900">Matching advisers</h2>
      <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
        {advisors.map((advisor) => <AdvisorCard advisor={advisor} />)}
      </div>

      <div class="mt-10 border-t border-line pt-6 text-sm text-calm">
        <p class="font-medium text-ink">Often compared with:</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {compareRoutes.map((item) => <a href={`/routes/${item.slug}/`} class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-calm hover:border-stone-300 hover:text-ink">{item.name}</a>)}
        </div>
      </div>
    </div>
  </section>
</Layout>
