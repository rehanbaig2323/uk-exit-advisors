---
import Layout from '@/components/Layout.astro';
import SectionHeading from '@/components/SectionHeading.astro';

const tiers = [
  {
    name: 'Free Listing',
    price: '£0',
    features: ['Firm name, HQ city, website', 'Adviser type and exit routes served', 'One contact link', 'Standard ranking in search results'],
  },
  {
    name: 'Enhanced Listing',
    price: '£97/mo',
    annual: '£97/mo · or £970/yr (save £194)',
    features: ['Everything in Free', 'Firm description (up to 120 words)', 'Up to 3 named key people', 'Up to 5 notable deals', 'Priority ranking within sector and region', 'Monthly enquiry analytics — profile views, inbound clicks to your site, referring search terms and visitor geography'],
  },
  {
    name: 'Featured Advisor',
    price: '£297/mo',
    annual: '£297/mo · or £2,970/yr (save £594)',
    features: ['Everything in Enhanced', 'Homepage editor’s picks placement', 'Sponsored position on matching route pages', 'Monthly newsletter feature', 'Quarterly deal-announcement feature'],
  },
];

const faqs = [
  {
    question: 'How do you verify firms?',
    answer: 'We check public websites, case studies and listing claims before publishing or updating a profile.',
  },
  {
    question: 'Do paid listings rank higher in search results?',
    answer: 'No. Paid tiers only affect clearly labelled featured or sponsored placements. Main search results stay neutral.',
  },
  {
    question: 'Do you take a commission on deals?',
    answer: 'No. The site does not take deal commission.',
  },
  {
    question: 'How do I claim an existing listing?',
    answer: 'Use the contact link on the profile or email us and we will verify the request before updating the listing.',
  },
  {
    question: 'Can I remove my firm from the directory?',
    answer: 'Yes. Send a removal request and we will review it.',
  },
];
---

<Layout fullTitle="For Advisors — UK Exit Advisors" description="Free and paid listing options for UK exit advisory firms.">
  <section class="border-b border-line bg-white/80">
    <div class="container-page py-20 sm:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow">For advisors</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 sm:text-6xl">Get in front of owners actively planning an exit.</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">UK Exit Advisors is an independent directory focused exclusively on business-exit advisory. Our visitors are not idly browsing - they are owners within 6-24 months of a liquidity event, and the advisors they work with.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" class="button-primary">Claim or upgrade</a>
          <a href="/about/" class="button-secondary">Read editorial policy</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-16 sm:py-20">
    <SectionHeading eyebrow="Pricing" title="Simple listing options" copy="Free by default, with optional paid upgrades for more detail and labelled placements." />
    <p class="mt-4 text-sm text-slate-600">15 UK firms listed · 5 exit routes covered · Directory launched April 2026</p>
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {tiers.map((tier) => (
        <div class="card flex flex-col p-8">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="eyebrow">{tier.name.toUpperCase()}</p>
              <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">{tier.name}</h2>
            </div>
            <p class="rounded-full bg-mist px-3 py-1 text-sm font-medium text-cedar">{tier.price}</p>
          </div>
          <p class="mt-3 text-sm text-slate-600">{tier.annual || tier.price}</p>
          <ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
            {tier.features.map((feature) => <li>{feature}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page py-8">
    <SectionHeading eyebrow="FAQ" title="Common questions" />
    <div class="mt-8 grid gap-4 lg:grid-cols-2">
      {faqs.map((faq) => (
        <details class="card p-6">
          <summary class="cursor-pointer list-none text-sm font-medium text-slate-900">{faq.question}</summary>
          <p class="mt-3 text-sm leading-7 text-slate-600">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="container-page py-16">
    <div class="card grid gap-6 p-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div>
        <p class="eyebrow">Ready to claim or upgrade?</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">Email info@ukexitadvisors.co.uk with your firm name in the subject line.</h2>
        <p class="mt-3 text-base leading-7 text-slate-600">We'll confirm your listing and, if you want to upgrade, send payment details within 2 working days.</p>
      </div>
      <div class="flex flex-col gap-3">
        <a href="mailto:info@ukexitadvisors.co.uk" class="button-primary text-center">Email us</a>
        <a href="/about/" class="button-secondary text-center">Editorial policy</a>
      </div>
    </div>
  </section>
</Layout>
