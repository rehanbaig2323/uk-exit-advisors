---
import Layout from '@/components/Layout.astro';
---

<Layout title="About" description="About UK Exit Advisors and how the directory is structured.">
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">About</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">A directory for thoughtful exits</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">Built for clear comparison, calm presentation and manual editing.</p>
      <div class="mt-8 card p-6 text-sm leading-7 text-slate-600">
        <p>Static-only. Database-free. Cloudflare Pages ready.</p>
      </div>
    </div>
  </section>
</Layout>
