---
import Layout from '@/components/Layout.astro';
---

<Layout fullTitle="Cookies — UK Exit Advisors" description="Cookie information for UK Exit Advisors." canonical={new URL('/cookies/', Astro.site).toString()}>
  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Cookies</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Cookie notice</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">This starter notice explains the main cookie and tracking categories used on the site. Replace the placeholder content with your final vendor, retention and consent details before launch.</p>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="max-w-4xl space-y-6 text-sm leading-7 text-slate-600">
      <p><span class="font-medium text-slate-900">Essential cookies.</span> These keep the site working and support basic functionality.</p>
      <p><span class="font-medium text-slate-900">Analytics.</span> If used, these help us understand which pages are useful and where improvements are needed.</p>
      <p><span class="font-medium text-slate-900">Placeholder note.</span> Add the names of any cookie tools, consent banner settings and opt-out instructions here.</p>
    </div>
  </section>
</Layout>
