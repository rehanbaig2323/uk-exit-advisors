---
import Seo from './Seo.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '@/styles/global.css';

const { title, description, canonical, image, fullTitle } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-stone-50 text-slate-800">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="data:," />
    <Seo title={title} description={description} canonical={canonical} image={image} fullTitle={fullTitle} />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
