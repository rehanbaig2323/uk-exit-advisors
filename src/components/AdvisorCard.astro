---
const { advisor } = Astro.props;
---

<article class="card flex h-full flex-col p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold text-slate-900"><a href={`/advisors/${advisor.slug}/`} class="hover:text-slate-700">{advisor.name}</a></h3>
      <p class="mt-1 text-sm text-slate-500">{advisor.location}</p>
    </div>
    {advisor.featured ? <span class="rounded-full border border-slate-200 bg-stone-50 px-3 py-1 text-xs font-medium text-slate-600">Featured</span> : null}
  </div>
  <p class="mt-4 text-sm leading-6 text-slate-600">{advisor.shortDescription}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {advisor.exitRoutes.slice(0, 2).map((route) => <span class="rounded-full bg-stone-100 px-3 py-1 text-xs text-slate-600">{route}</span>)}
  </div>
  <dl class="mt-6 grid gap-3 text-sm text-slate-600">
    <div>
      <dt class="font-medium text-slate-900">Focus</dt>
      <dd>{advisor.services.slice(0, 2).join(', ')}</dd>
    </div>
    <div>
      <dt class="font-medium text-slate-900">Verified</dt>
      <dd>{advisor.lastVerified}</dd>
    </div>
  </dl>
  <div class="mt-6 flex items-center justify-between gap-3 pt-4">
    <a href={`/advisors/${advisor.slug}/`} class="text-sm font-medium text-slate-900 underline decoration-stone-300 underline-offset-4 hover:decoration-slate-900">View profile</a>
    <a href={`mailto:${advisor.email}?subject=Claim%20or%20correct%20profile%20for%20${encodeURIComponent(advisor.name)}`} class="text-sm text-slate-500 hover:text-slate-900">Claim/correct</a>
  </div>
</article>
