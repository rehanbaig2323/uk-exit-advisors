---
import {
  getAdvisorDisplayName,
  getAdvisorFaviconUrl,
  getAdvisorLogoUrl,
} from '@/lib/advisor-logo';

const { advisor, size = 'md', class: className = '' } = Astro.props;
const name = getAdvisorDisplayName(advisor);
const explicitLogo = getAdvisorLogoUrl(advisor);
const faviconUrl = getAdvisorFaviconUrl(advisor);
const primarySrc = explicitLogo || faviconUrl;
const fallbackSrc = explicitLogo ? faviconUrl : '';
const resolvedSize = ['sm', 'md', 'lg'].includes(size) ? size : 'md';

const sizeClasses = {
  sm: 'h-14 w-14 rounded-2xl',
  md: 'h-16 w-16 rounded-3xl',
  lg: 'h-20 w-20 rounded-[1.35rem]',
};

const paddingClasses = {
  sm: 'p-2',
  md: 'p-2.5',
  lg: 'p-3',
};

const fallbackBadgeClasses = {
  sm: 'h-8 w-8',
  md: 'h-9 w-9',
  lg: 'h-10 w-10',
};
---

<div class={`relative flex shrink-0 items-center justify-center overflow-hidden border border-stone-200 bg-white/90 shadow-sm ${sizeClasses[resolvedSize]} ${className}`}>
  {primarySrc ? (
    <img
      src={primarySrc}
      alt={`${name} logo`}
      class={`h-full w-full object-contain ${paddingClasses[resolvedSize]}`}
      loading="lazy"
      decoding="async"
      referrerpolicy="no-referrer"
      data-logo-state="primary"
      data-fallback-src={fallbackSrc}
      onerror={`const img = this; const fallback = img.nextElementSibling; if (img.dataset.logoState === 'fallback' || !img.dataset.fallbackSrc) { img.style.display = 'none'; if (fallback) fallback.hidden = false; return; } img.dataset.logoState = 'fallback'; img.src = img.dataset.fallbackSrc;`}
    />
  ) : null}
  <div hidden={Boolean(primarySrc)} class={`flex items-center justify-center rounded-[inherit] bg-gradient-to-br from-stone-100 via-stone-50 to-stone-200 ${sizeClasses[resolvedSize]}`} aria-hidden="true">
    <div class={`rounded-full border border-stone-300 bg-white shadow-sm ${fallbackBadgeClasses[resolvedSize]} flex items-center justify-center`}>
      <div class="h-3.5 w-3.5 rounded-full border border-stone-400/80" />
    </div>
  </div>
</div>
