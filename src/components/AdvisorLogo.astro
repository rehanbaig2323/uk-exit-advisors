---
import {
  getAdvisorDisplayName,
  getAdvisorFaviconUrl,
  getAdvisorLogoUrl,
} from '@/lib/advisor-logo';

const { advisor, size = 'md', class: className = '' } = Astro.props;
const name = getAdvisorDisplayName(advisor);
const explicitLogo = getAdvisorLogoUrl(advisor);
const faviconUrl = getAdvisorFaviconUrl(advisor);
const primarySrc = explicitLogo || faviconUrl;
const resolvedSize = ['sm', 'md', 'lg'].includes(size) ? size : 'md';

const sizeClasses = {
  sm: 'h-14 w-14 rounded-2xl',
  md: 'h-16 w-16 rounded-3xl',
  lg: 'h-20 w-20 rounded-[1.35rem]',
};

const paddingClasses = {
  sm: 'p-2',
  md: 'p-2.5',
  lg: 'p-3',
};

const fallbackClasses = {
  sm: 'p-0.5',
  md: 'p-0.5',
  lg: 'p-1',
};

const fallbackMarkup = `<div class="h-full w-full rounded-[inherit] border border-stone-200/80 bg-transparent" aria-hidden="true"></div>`;
---

<div class={`relative flex shrink-0 items-center justify-center overflow-hidden bg-transparent ${sizeClasses[resolvedSize]} ${className}`}>
  {primarySrc ? (
    <img
      src={primarySrc}
      alt={`${name} logo`}
      class={`h-full w-full object-contain ${paddingClasses[resolvedSize]}`}
      loading="lazy"
      decoding="async"
      data-logo-state="primary"
      onerror={`const img = this; const wrap = img.parentElement; if (!wrap) return; if (img.dataset.logoState === 'fallback') { wrap.innerHTML = ${JSON.stringify(fallbackMarkup)}; return; } img.dataset.logoState = 'fallback'; wrap.innerHTML = ${JSON.stringify(fallbackMarkup)};`}
    />
  ) : (
    <div class={`h-full w-full rounded-[inherit] border border-stone-200/80 bg-transparent ${fallbackClasses[resolvedSize]}`} aria-hidden="true" />
  )}
</div>
