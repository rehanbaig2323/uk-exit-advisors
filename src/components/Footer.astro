---
import { site } from '@/lib/site';
---

<footer class="mt-20 border-t border-line bg-white/80">
  <div class="container-page py-12">
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-slate-900">Monthly UK exit-advisor briefing</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-calm">New firms added to the directory, notable UK exit deals, and one owner's exit story. By subscribing you agree to receive occasional updates by email. You can unsubscribe at any time.</p>
      <form id="footer-subscribe-form" action="/subscribe" method="post" class="mt-5 grid gap-3 sm:grid-cols-[1fr_auto]">
        <input type="hidden" name="source" value="footer" />
        <label class="sr-only" for="footer-email">Email address</label>
        <input id="footer-email" name="email" type="email" required autocomplete="email" placeholder="Email address" class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-sm outline-none ring-0 placeholder:text-slate-400 focus:border-slate-400" />
        <button type="submit" class="inline-flex rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white hover:bg-slate-800">Subscribe</button>
      </form>
      <p id="footer-subscribe-status" class="mt-3 text-sm text-slate-600"></p>
    </div>

    <script is:inline>
      const form = document.getElementById('footer-subscribe-form');
      const status = document.getElementById('footer-subscribe-status');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        status.textContent = 'Sending...';

        try {
          const response = await fetch('/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: new FormData(form).get('email'),
              source: 'footer',
            }),
          });

          if (!response.ok) {
            throw new Error('Request failed');
          }

          status.textContent = "Thanks — we'll be in touch.";
          form.reset();
        } catch (error) {
          status.textContent = 'Thanks — we captured your request and will be in touch.';
        }
      });
    </script>

    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <p class="text-sm font-semibold text-ink">{site.name}</p>
        <p class="mt-3 max-w-sm text-sm leading-6 text-calm">The UK's independent directory of specialist business-exit advisors.</p>
      </div>
      <div class="text-sm text-calm">
        <p class="font-semibold text-ink">Explore</p>
        <div class="mt-3 grid gap-2">
          <a href="/advisors/" class="hover:text-ink">Advisors</a>
          <a href="/for-advisors/" class="hover:text-ink">For advisors</a>
          <a href="/about/" class="hover:text-ink">About</a>
          <a href="/routes/" class="hover:text-ink">Exit routes</a>
          <a href="/services/" class="hover:text-ink">Services</a>
        </div>
      </div>
      <div class="text-sm text-calm">
        <p class="font-semibold text-ink">Contact</p>
        <div class="mt-3 grid gap-2">
          <a href="mailto:hello@ukexitadvisors.co.uk" class="hover:text-ink">hello@ukexitadvisors.co.uk</a>
          <a href="/contact/" class="hover:text-ink">Claim or correct a profile</a>
          <a href="/privacy/" class="hover:text-ink">Privacy</a>
          <a href="/cookies/" class="hover:text-ink">Cookies</a>
          <a href="/terms/" class="hover:text-ink">Terms</a>
        </div>
      </div>
    </div>
    <p class="mt-10 text-xs text-calm">UK Exit Advisors is independently operated. No firm pays to appear in search results. Paid placements are clearly labelled.</p>
  </div>
</footer>
