---
const { route } = Astro.props;
---

<a href={`/routes/${route.slug}/`} class="card group block p-6 transition-transform hover:-translate-y-0.5 hover:shadow-soft">
  <h3 class="text-lg font-semibold text-slate-900">{route.name}</h3>
  <p class="mt-2 text-sm leading-6 text-slate-600">{route.summary}</p>
  <p class="mt-4 text-sm font-medium text-ink">Read guide <span class="transition-transform group-hover:translate-x-0.5">→</span></p>
</a>
